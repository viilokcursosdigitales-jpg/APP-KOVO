# Copia este archivo como `.env` en la raíz del repo (recomendado) o como `backend/.env`.
# Si la misma clave está en ambos, gana la del `.env` de la raíz (se carga primero).

# Supabase: directa db.<ref>.supabase.co:5432 o pooler IPv4 (usuario postgres.<ref>).
# Session pooler suele usar puerto 5432; transaction 6543 (el código añade ?pgbouncer=true).
DATABASE_URL=postgresql://postgres.tuprojecto:[YOUR_PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Alias opcional:
# DB_URL=

# Postgres local sin TLS:
# DB_SSL=false

PORT=3000
HOST=0.0.0.0

JWT_SECRET=genera-un-secreto-largo-y-aleatorio

# Orígenes del front para fetch (https + host, sin path). El servidor también añade el origen de SHOPIFY_APP_URL / SHOPIFY_REDIRECT_URI si son https.
CORS_ORIGINS=https://tudominio.com,https://www.tudominio.com

TRUST_PROXY=1

# DB_POOL_MAX=20

# Depuración: muestra DATABASE_URL enmascarada y rutas cargadas (también en desarrollo)
# LOG_ENV_DEBUG=1

# STATIC_DIR=/ruta/absoluta/al/dist

# Opcional: si coinciden con el App ID guardado en la conexión Meta, se usa este secret al renovar tokens (fb_exchange_token).
# En multi-tenant, la renovación usa por defecto app_id y app_secret de cada fila en meta_connections.
# META_APP_ID=
# META_APP_SECRET=

# Zona horaria del cron diario de renovación de tokens evaluator (node-cron).
# CRON_TZ=Europe/Madrid

# Versión Graph API (también usada en la renovación).
# META_GRAPH_VERSION=v21.0

# Shopify (OAuth + webhooks). El callback debe coincidir con la URL registrada en la app Shopify.
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_APP_URL=https://kovo.services
# (necesaria también para registrar automáticamente el webhook app/uninstalled tras OAuth)
# SHOPIFY_REDIRECT_URI=https://kovo.services/api/shopify/callback
# (misma cadena exacta que en Partner Dashboard → App setup → Allowed redirection URL(s), sin espacios ni barra final)
# SHOPIFY_SCOPES=read_orders,write_orders,read_products,write_products,read_inventory,write_inventory
# SHOPIFY_API_VERSION=2026-04
