# Coloca aquí tu `.env` en la raíz del monorepo (junto a /frontend y /backend).
# El servidor carga primero este archivo y luego `backend/.env` solo para variables que falten.

DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.tuprojecto.supabase.co:5432/postgres
JWT_SECRET=genera-un-secreto-largo-y-aleatorio
CORS_ORIGINS=https://tudominio.com,https://www.tudominio.com
TRUST_PROXY=1

# Correo (invitaciones, recuperar contraseña): ver variables detalladas en backend/.env.example
# PUBLIC_APP_URL=https://tudominio.com
# RESEND_API_KEY=re_...
# o SMTP_HOST / SMTP_USER / SMTP_PASS

# Hotmart: token del webhook (panel Hotmart → Webhooks) y URL de checkout en el frontend (.env del front).
# HOTMART_WEBHOOK_TOKEN=
# VITE_HOTMART_CHECKOUT_URL=https://pay.hotmart.com/TU_PRODUCTO
